# Database — SQLite works out of the box with zero setup.
# To use Postgres instead (e.g. Railway/Supabase in production), change the
# provider in prisma/schema.prisma to "postgresql" and set this to your
# Postgres connection string.
DATABASE_URL="file:./dev.db"

# Auth secret used to sign session JWTs — change this to a long random
# string in production. Generate one with: openssl rand -base64 48
# (Password reset tokens are random bytes hashed with SHA-256 and stored on
# the user record, not JWTs, so no separate secret is needed for those.)
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# Public site URL (used for share links, absolute URLs, SEO)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seed script — creates this admin account
SEED_ADMIN_EMAIL="admin@photospot.ge"
SEED_ADMIN_PASSWORD="Admin123!"
